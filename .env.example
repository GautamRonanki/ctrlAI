AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret

# Google OAuth app credentials used by Token Vault / connected Google integrations.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# GitHub OAuth app credentials used by Token Vault / connected GitHub integrations.
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token
OPENAI_API_KEY=sk-your-openai-api-key

# Secret key for FastAPI session cookie encryption. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=generate-a-random-64-char-hex-secret
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# Auth0 user ID that receives CIBA push notifications for high-stakes action approvals.
# Format example: auth0|1234567890abcdef
EMERGENCY_COORDINATOR_USER_ID=auth0|your-emergency-coordinator-user-id

# Default Auth0 user ID used for local development or seeded demo flows.
# Format examples: google-oauth2|123456789012345678901 or auth0|1234567890abcdef
DEFAULT_AUTH0_USER_ID=google-oauth2|your-default-user-id

# Email address that receives security alert notifications.
ADMIN_ALERT_EMAIL=admin@example.com

# Optional example-only setting: password-protect the Streamlit admin dashboard.
# Leave blank for local development if dashboard auth is not needed.
DASHBOARD_PASSWORD=
