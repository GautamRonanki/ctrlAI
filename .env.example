AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
OPENAI_API_KEY=your-openai-key
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
APP_BASE_URL=http://localhost:8000

# Auth0 user ID that receives CIBA push notifications for high-stakes action approvals.
# Find this in the Auth0 dashboard under User Management > Users (format: auth0|...).
EMERGENCY_COORDINATOR_USER_ID=auth0|your-user-id-here

# Email address for security alert notifications (e.g. rate limit exceeded alerts).
ADMIN_ALERT_EMAIL=admin@example.com

# Secret key for FastAPI session cookie encryption. Must be a long random string.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=generate-a-random-secret-key-here

# Optional: password-protect the Streamlit admin dashboard.
# If not set, the dashboard is accessible without authentication (convenient for local dev).
# Set this for any deployed or shared environment.
DASHBOARD_PASSWORD=
